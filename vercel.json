{
    "version": 2,
    "framework": null,
    "outputDirectory": ".",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:HORTAh8sLBIgpIUmQ5n5YPxhHJMzEvo4tErlL2wrUfI=",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": ":memory:",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_STORE": "array",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr"
    },
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images|profile-frames|card)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
