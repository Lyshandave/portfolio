{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "buildCommand": "npm run build",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:HORTAh8sLBIgpIUmQ5n5YPxhHJMzEvo4tErlL2wrUfI=",
